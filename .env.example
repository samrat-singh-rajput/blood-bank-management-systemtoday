# ==============================================================================
# BLOOD BANK MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# This is an example configuration file. Copy this file to `.env` in your root
# directory and populate the values according to your environment.
# DO NOT commit your actual `.env` file containing secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION GENERAL SETTINGS
# ------------------------------------------------------------------------------
# General application metadata and environment settings
APP_NAME="Blood Bank Management System"
APP_ENV=development # Options: development, staging, production
APP_DEBUG=true
APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 2. FRONTEND / VITE SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Configuration for Vite development server and API routing
VITE_SERVER_HOST=0.0.0.0
VITE_SERVER_PORT=3000
VITE_API_URL=http://localhost:5000/api.php
VITE_STORAGE_MODE=local # Options: local (localStorage demo mode), mongodb (MongoDB Atlas backend)

# ------------------------------------------------------------------------------
# 3. DATABASE CONFIGURATION (MongoDB Atlas)
# ------------------------------------------------------------------------------
# MongoDB connection URI and Node server port
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/bloodbank_system?retryWrites=true&w=majority
PORT=5000

# ------------------------------------------------------------------------------
# 4. GOOGLE GEMINI AI CONFIGURATION
# ------------------------------------------------------------------------------
# API Key for Google Gemini AI (used for Samrat Assistant, AI Health Tips, 
# Image Medical Certificate Analysis, and Audio Transcription)
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. FAST2SMS GATEWAY CONFIGURATION
# ------------------------------------------------------------------------------
# Fast2SMS API Key for sending OTPs and SMS notifications to donors/patients
# Get your key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key_here
SMS_SENDER_ID=BLDBNK
SMS_ENABLED=true

# ------------------------------------------------------------------------------
# 6. SMTP / EMAIL CONFIGURATION (PHPMailer)
# ------------------------------------------------------------------------------
# SMTP server settings used by mail_config.php for sending OTP registration emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# For Gmail, use a 16-character App Password (not your primary Google account password)
SMTP_PASS=your_app_password_here
SMTP_SECURE=tls # Options: tls, ssl
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME="Blood Bank Project"

# ------------------------------------------------------------------------------
# 7. GOOGLE SIGN-IN CREDENTIALS
# ------------------------------------------------------------------------------
# Set the Google OAuth Client ID for real authentication.
# Once set, the official Google button will render on the Registration Details page.
VITE_GOOGLE_CLIENT_ID=293103900402-5g0c408ipeuaa4e9gvhqghnks16tm3iu.apps.googleusercontent.com
GOOGLE_CLIENT_ID=293103900402-5g0c408ipeuaa4e9gvhqghnks16tm3iu.apps.googleusercontent.com
